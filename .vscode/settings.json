{
  "css.lint.unknownAtRules": "ignore",
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  "files.exclude": {
    "node_modules": true,
    ".next": true,
    "out": true,
    ".venv": true,
    ".claude": true,
    "**/.git": true
  },
  "search.exclude": {
    "node_modules": true,
    ".next": true,
    "out": true,
    ".venv": true,
    ".claude": true
  }
}
