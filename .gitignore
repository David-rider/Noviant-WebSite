# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# deployment packages — build artifacts, not source
*.zip

# claude code worktrees & internal data
.claude/

# temporary work directories
tmp_*/
tmp_zip_check/

# python virtual environments
.venv/
venv/

# one-off audit / generate scripts dropped in root
audit.js
check_i18n.js
generate_logos.js
parse_form.py

# build & lint result dumps
build-results*.txt
eslint-results*.json
eslint_audit.json
lint_*.txt

# raw HTML snapshots
noviant_production_home.html
partners_raw.html
